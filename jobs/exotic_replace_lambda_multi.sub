# HTCondor submit file: Exotic Fluid Replacing Lambda (4 independent chains)
# Each chain gets its own output path via $(Process)

executable      = jobs/run_exotic_replace_lambda_multi.sh

arguments       = $(Process)

output          = logs/exotic_replace_lambda_$(Process).condor.out
error           = logs/exotic_replace_lambda_$(Process).condor.err
log             = logs/exotic_replace_lambda_$(Process).condor.log

request_cpus    = 1
request_memory  = 4 GB
request_disk    = 4 GB

queue 4
